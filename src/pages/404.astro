---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="glass-strong p-8 sm:p-12 max-w-md">
      <h1 class="text-6xl sm:text-8xl font-bold text-white mb-4">404</h1>
      <h2 class="text-xl sm:text-2xl font-semibold text-white mb-4">Page Not Found</h2>
      <p class="text-white/70 mb-8">
        Sorry, the page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-hover text-white font-semibold rounded-lg transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Back to Home
      </a>
    </div>
  </div>
</Layout>
