---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('vlog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout title="Vlog" description="Video content with full transcripts">
  <div>
    <!-- Header -->
    <header class="glass-strong p-6 sm:p-8 mb-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2 flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="text-red-500">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
            <path d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="white"/>
          </svg>
          Vlog
        </h1>
        <p class="text-white/70">Video content with full transcripts</p>
      </header>

      <!-- Posts grid -->
      {posts.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <a
              href={`/vlog/${post.id}`}
              class="glass p-6 hover:bg-white/20 transition-all duration-300 hover:scale-[1.02] block group"
            >
              <div class="aspect-video mb-4 rounded-lg overflow-hidden relative">
                <img
                  src={`https://i.ytimg.com/vi/${post.data.videoId}/mqdefault.jpg`}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/30 flex items-center justify-center">
                  <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>
              </div>

              <div class="flex items-center gap-2 mb-2">
                {post.data.channelName && (
                  <span class="text-white/50 text-xs">{post.data.channelName}</span>
                )}
              </div>

              <h2 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">
                {post.data.title}
              </h2>

              <p class="text-white/60 text-sm mb-3 line-clamp-2">{post.data.description}</p>

              <div class="flex items-center justify-between text-white/50 text-sm">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.duration && (
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {post.data.duration}
                  </span>
                )}
              </div>

              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-3">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="px-2 py-0.5 bg-white/10 text-white/50 text-xs rounded">
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center">
          <p class="text-white/70">No videos yet. Check back soon!</p>
        </div>
      )}
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
