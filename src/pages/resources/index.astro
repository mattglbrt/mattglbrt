---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('resources'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout title="Resources" description="Articles, guides, and helpful resources">
  <div>
    <!-- Header -->
    <header class="glass-strong p-6 sm:p-8 mb-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2 flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
          </svg>
          Resources
        </h1>
        <p class="text-white/70">Articles, guides, and helpful resources</p>
      </header>

      <!-- Posts list -->
      {posts.length > 0 ? (
        <div class="space-y-4">
          {posts.map((post) => (
            <a
              href={`/resources/${post.id}`}
              class="glass p-6 hover:bg-white/20 transition-all duration-300 block group"
            >
              <div class="flex gap-6">
                {post.data.heroImage && (
                  <div class="w-32 h-24 rounded-lg overflow-hidden flex-shrink-0 hidden sm:block">
                    <img
                      src={post.data.heroImage}
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="flex-1">
                  <h2 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">
                    {post.data.title}
                  </h2>

                  <p class="text-white/60 text-sm mb-3 line-clamp-2">{post.data.description}</p>

                  <div class="flex items-center gap-4 text-white/50 text-sm">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    {post.data.tags.length > 0 && (
                      <div class="flex gap-1">
                        {post.data.tags.slice(0, 2).map((tag) => (
                          <span class="px-2 py-0.5 bg-white/10 text-white/50 text-xs rounded">
                            #{tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-white/60 transition-colors flex-shrink-0 self-center">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center">
          <p class="text-white/70">No resources yet. Check back soon!</p>
        </div>
      )}
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
