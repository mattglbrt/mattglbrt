---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';

const issues = (await getCollection('newsletter'))
  .filter((issue) => !issue.data.draft)
  .sort((a, b) => b.data.issueNumber - a.data.issueNumber);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<Layout title="Newsletter Archive" description="Browse past editions of the newsletter">
  <div>
    <!-- Header -->
    <header class="glass-strong p-6 sm:p-8 mb-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2 flex items-center justify-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          Newsletter Archive
        </h1>
        <p class="text-white/70">Browse past editions of the newsletter</p>
      </header>

      <!-- Subscribe section -->
      <div class="mb-8">
        <NewsletterSignup
          title="Never miss an issue"
          description="Subscribe to get the newsletter delivered to your inbox."
        />
      </div>

      <!-- Issues list -->
      {issues.length > 0 ? (
        <div class="space-y-4">
          {issues.map((issue) => (
            <a
              href={`/newsletter/${issue.id}`}
              class="glass p-6 hover:bg-white/20 transition-all duration-300 block group"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="px-2 py-0.5 bg-accent/20 text-accent text-xs font-medium rounded-full">
                      Issue #{issue.data.issueNumber}
                    </span>
                    <time datetime={issue.data.pubDate.toISOString()} class="text-white/50 text-sm">
                      {formatDate(issue.data.pubDate)}
                    </time>
                  </div>
                  <h2 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">
                    {issue.data.title}
                  </h2>
                  <p class="text-white/60 text-sm">{issue.data.description}</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/30 group-hover:text-white/60 transition-colors flex-shrink-0">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center">
          <p class="text-white/70">No newsletter issues yet. Subscribe to be the first to know!</p>
        </div>
      )}
  </div>
</Layout>
