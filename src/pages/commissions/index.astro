---
import TextmodeLayout from "../../layouts/textmode/TextmodeLayout.astro";
import { renderAnsiText } from "../../modules/textmode/ansi/render";
import { link } from "../../modules/textmode/core/html";
import { commissionStatus, commissionStatusLine, textmodeConfig } from "../../config";

// Availability lives in src/config/commissions.ts — flip it there and both this
// page and the home page "go" link retune together.
const statusLine = commissionStatusLine[commissionStatus];

// Each paragraph and service is one logical line so the renderer word-wraps it
// cleanly to whatever column width the page is at — no hand-wrapped lines to
// scramble. Blank lines separate the services so the list stays scannable.
const intro = `~ commissions

Commissions across the whole hobby: miniature painting, kitbashing, assembly, scale modeling, terrain building, and 3D printing.

> #[C|Miniature painting] — characters, units, and full armies, offered at two levels. Prep tier: assembly, priming, and airbrushed base colors cut in — I handle the tedious groundwork so you can go hard on the details yourself. Or tabletop tier: a finished level I'd like to think lands a bit beyond standard for most tables.

> #[C|Kitbashing] — conversions and combining kits into something that isn't on any sprue.

> #[C|Mini assembly] — clean builds, gap-filled and ready for the brush.

> #[C|Scale modeling] — model kits built and finished to display standard.

> #[C|Terrain building] — tables, boards, and scenery built to match your game and your models.

> #[C|3D printing] — printed minis, parts, and bits made to spec.

How it works: reach out using the form below, or come hang in my Discord: https://discord.gg/9kzUhhk86r — tell me about your project, budget, and timeline for getting the models back. I'll give you a price and timeline for completion.

status: ${statusLine}`;

const introHtml = renderAnsiText(intro, textmodeConfig.bodyWidth);
const footerHtml = `\nret ${link("/", "<home>")}\n`;
const projectTypes = [
  "Miniature painting",
  "Kitbashing",
  "Mini assembly",
  "Scale modeling",
  "Terrain building",
  "3D printing",
  "Something else"
];
---

<TextmodeLayout
  title="Commissions"
  description="Hire Matt Gilbert for hand-painted miniatures, sculpting, and commissioned art. Conversation-first inquiries."
>
  <section class="textmode-wrap commission-wrap">
    <pre class="textmode-pre commission-pre" set:html={introHtml}></pre>

    {/* TODO(matt): drop a few example pieces here once you pick them. */}

    <form
      class="commission-form"
      name="commission-inquiry"
      method="POST"
      action="/commissions/success/"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="commission-inquiry" />
      <p class="commission-hp">
        <label>Leave this field empty: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <label class="commission-field">
        <span>name</span>
        <input type="text" name="name" required autocomplete="name" />
      </label>

      <label class="commission-field">
        <span>email</span>
        <input type="email" name="email" required autocomplete="email" />
      </label>

      <label class="commission-field">
        <span>project type</span>
        <select name="project-type">
          {projectTypes.map((type) => <option value={type}>{type}</option>)}
        </select>
      </label>

      <label class="commission-field">
        <span>budget / timeline</span>
        <input type="text" name="budget-timeline" placeholder="rough budget + when you need it" />
      </label>

      <label class="commission-field">
        <span>the project</span>
        <textarea name="description" rows="6" required placeholder="what you want made, model count, scheme, references..."></textarea>
      </label>

      <button type="submit" class="commission-submit">~ send inquiry</button>
    </form>

    <pre class="textmode-pre commission-pre" set:html={footerHtml}></pre>
  </section>
</TextmodeLayout>
