---
import Layout from '../layouts/Layout.astro';
import ProfileHeader from '../components/ProfileHeader.astro';
import RevenueTracker from '../components/RevenueTracker.astro';
import SocialLinks from '../components/SocialLinks.astro';
import YouTubeLatest from '../components/YouTubeLatest.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';

// ============================================
// CONFIGURATION - Update these values!
// ============================================

// Your profile info
const profile = {
  name: "Matt Gilbert",
  tagline: "Artist | Husband | Father",
  avatarUrl: "/mattglbrt.jpg",
};

// Your social media links
// Available icons: twitter, youtube, instagram, tiktok, linkedin, github,
// discord, twitch, spotify, threads, bluesky, email, website, podcast
const socialLinks = [
  { name: "YouTube", url: "https://www.youtube.com/@mattglbrt", icon: "youtube" },
  { name: "TikTok", url: "https://www.tiktok.com/@mattglbrt", icon: "tiktok" },
  { name: "Instagram", url: "https://www.instagram.com/hobbinomicon/", icon: "instagram" },
  { name: "Website", url: "https://buzzardstradingpost.com", icon: "website" },
  { name: "Email", url: "mailto:matt@goeveryway.com", icon: "email" },
  { name: "Discord", url: "https://discord.com/invite/5YnP7KrQH3", icon: "discord" },
];

// Your YouTube channels - add channel IDs to fetch latest videos
// Find channel ID: Go to channel > About > Share > Copy channel ID
const youtubeChannels = [
  { name: "Matt Gilbert", channelId: "UClfiOtzwwm9C4Mw8Fh06oIg" },
];

// YouTube API Key (optional - get from Google Cloud Console)
// Without this, placeholder videos will be shown
const youtubeApiKey = import.meta.env.YOUTUBE_API_KEY || "";

// Revenue tracking - Building in Public
// Update these values as your revenue grows!
const revenue = {
  total: 35, // Total revenue generated
  goal: 1000, // Your revenue goal (optional - remove to hide progress bar)
  sources: [
    { name: "eBay", amount: 35, icon: "ebay" },
  ],
};
---

<Layout title={profile.name} description={profile.tagline}>
  <div class="space-y-8">
    <!-- Profile Header -->
    <ProfileHeader
      name={profile.name}
      tagline={profile.tagline}
      avatarUrl={profile.avatarUrl}
    />

    <!-- Revenue Tracker - Building in Public -->
    <RevenueTracker
      totalRevenue={revenue.total}
      goal={revenue.goal}
      sources={revenue.sources}
    />

    <!-- Latest YouTube Videos -->
    <section class="glass p-6">
      <YouTubeLatest
        channels={youtubeChannels}
        apiKey={youtubeApiKey}
      />
    </section>

    <!-- Newsletter Signup -->
    <section id="newsletter">
      <NewsletterSignup />
    </section>

    <!-- Social Links -->
    <section class="glass-strong p-6">
      <h2 class="text-xl font-bold text-white mb-4 text-center">Connect With Me</h2>
      <SocialLinks links={socialLinks} />
    </section>
  </div>
</Layout>
