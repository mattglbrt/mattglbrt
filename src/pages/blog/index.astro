---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout title="Blog" description="Articles, video transcripts, and more">
  <main class="min-h-screen py-8 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Back to home -->
      <a href="/" class="inline-flex items-center gap-2 text-white/70 hover:text-white mb-6 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        Home
      </a>

      <!-- Header -->
      <header class="glass-strong p-6 sm:p-8 mb-8 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">Blog</h1>
        <p class="text-white/70">Articles, video transcripts, and insights</p>
      </header>

      <!-- Posts grid -->
      {posts.length > 0 ? (
        <div class="grid gap-6 md:grid-cols-2">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="glass p-6 hover:bg-white/20 transition-all duration-300 hover:scale-[1.02] block group"
            >
              {post.data.videoId && (
                <div class="aspect-video mb-4 rounded-lg overflow-hidden relative">
                  <img
                    src={`https://i.ytimg.com/vi/${post.data.videoId}/mqdefault.jpg`}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-black/30 flex items-center justify-center">
                    <div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="white">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  </div>
                </div>
              )}

              {post.data.heroImage && !post.data.videoId && (
                <div class="aspect-video mb-4 rounded-lg overflow-hidden">
                  <img
                    src={post.data.heroImage}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}

              <div class="flex items-center gap-2 mb-2">
                {post.data.videoId && (
                  <span class="px-2 py-0.5 bg-red-500/20 text-red-300 text-xs rounded-full">
                    Video
                  </span>
                )}
                {post.data.channelName && (
                  <span class="text-white/50 text-xs">{post.data.channelName}</span>
                )}
              </div>

              <h2 class="text-xl font-bold text-white mb-2 group-hover:text-accent transition-colors">
                {post.data.title}
              </h2>

              <p class="text-white/60 text-sm mb-3 line-clamp-2">{post.data.description}</p>

              <div class="flex items-center justify-between text-white/50 text-sm">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.duration && (
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                    {post.data.duration}
                  </span>
                )}
              </div>

              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-3">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="px-2 py-0.5 bg-white/10 text-white/50 text-xs rounded">
                      #{tag}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="glass p-8 text-center">
          <p class="text-white/70">No posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </main>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
