---
import Layout from '../layouts/Layout.astro';

// ============================================
// TOOLS CONFIGURATION - Add your tools here!
// ============================================

interface Tool {
  name: string;
  description: string;
  url: string;
  category: string;
  isAffiliate?: boolean;
}

// Category descriptions (optional)
const categoryDescriptions: Record<string, string> = {
  "AI": "I use AI to be more productive and do the inhuman work so I can focus my efforts on human creative work. I do not use AI for images or any creative writing. Instead I use it to help me edit, program, organize, and increase my business productivity.",
};

const tools: Tool[] = [
  {
    name: "eBay",
    description: "My main selling platform for flipping items",
    url: "https://www.ebay.com",
    category: "Selling Platforms",
    isAffiliate: false,
  },
  {
    name: "Astro",
    description: "The framework powering this website",
    url: "https://astro.build",
    category: "Tech Stack",
    isAffiliate: false,
  },
  {
    name: "VS Code",
    description: "My code editor of choice",
    url: "https://code.visualstudio.com",
    category: "Tech Stack",
    isAffiliate: false,
  },
  {
    name: "Netlify",
    description: "Where this site is hosted",
    url: "https://www.netlify.com",
    category: "Tech Stack",
    isAffiliate: false,
  },
  {
    name: "ChatGPT",
    description: "I use this to organize my notes and turn them into workable ideas",
    url: "https://chat.openai.com",
    category: "AI",
    isAffiliate: false,
  },
  {
    name: "Claude",
    description: "I use Claude Code to make things faster and increase coding productivity",
    url: "https://claude.ai",
    category: "AI",
    isAffiliate: false,
  },
  {
    name: "Perplexity",
    description: "I use this to research, fact check, and find expert sources",
    url: "https://www.perplexity.ai",
    category: "AI",
    isAffiliate: false,
  },
];

// Group tools by category
const categories = tools.reduce((acc, tool) => {
  if (!acc[tool.category]) {
    acc[tool.category] = [];
  }
  acc[tool.category].push(tool);
  return acc;
}, {} as Record<string, Tool[]>);
---

<Layout title="Tools | Matt Gilbert" description="The tools I actually use and recommend">
  <div class="space-y-8">
    <!-- Header -->
    <header class="glass-strong p-6 sm:p-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        Tools I Use
      </h1>
      <div class="text-white/80 space-y-3">
        <p>
          These are the tools that I actually use myself. I'm not listing things just because they have affiliate programs - these are genuinely part of my workflow.
        </p>
        <p class="text-white/60 text-sm">
          Some links might be affiliate links, but those are just nice kickbacks to me for stuff I already support and stand by. I do not use tools because of the affiliate - I only recommend what I'd use regardless.
        </p>
      </div>
    </header>

    <!-- Tools by Category -->
    {Object.keys(categories).length > 0 ? (
      Object.entries(categories).map(([category, categoryTools]) => (
        <section class="glass p-6">
          <h2 class="text-xl font-bold text-white mb-2">{category}</h2>
          {categoryDescriptions[category] && (
            <p class="text-white/60 text-sm mb-4">{categoryDescriptions[category]}</p>
          )}
          <div class="grid gap-4 sm:grid-cols-2">
            {categoryTools.map((tool) => (
              <a
                href={tool.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block p-4 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg transition-all group"
              >
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-semibold text-white group-hover:text-accent transition-colors">
                    {tool.name}
                  </h3>
                  <div class="flex items-center gap-2">
                    {tool.isAffiliate && (
                      <span class="text-xs px-2 py-0.5 bg-accent/20 text-accent rounded">
                        Affiliate
                      </span>
                    )}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 group-hover:text-white/60 transition-colors">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                      <polyline points="15 3 21 3 21 9"/>
                      <line x1="10" x2="21" y1="14" y2="3"/>
                    </svg>
                  </div>
                </div>
                <p class="text-white/60 text-sm mt-2">{tool.description}</p>
              </a>
            ))}
          </div>
        </section>
      ))
    ) : (
      <section class="glass p-6 text-center">
        <p class="text-white/60">Tools coming soon! Check back later.</p>
      </section>
    )}
  </div>
</Layout>
