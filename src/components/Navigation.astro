---
interface NavLink {
  name: string;
  href: string;
}

interface Props {
  links?: NavLink[];
}

const { links = [
  { name: 'Blog', href: '/blog' },
  { name: 'Newsletter', href: '/newsletter' },
] } = Astro.props;
---

<nav class="glass-subtle p-2 mb-8 flex justify-center gap-1 sm:gap-2 flex-wrap">
  {links.map((link) => (
    <a
      href={link.href}
      class="px-4 py-2 text-white/80 hover:text-white hover:bg-white/10 rounded-lg transition-all duration-200 text-sm sm:text-base"
    >
      {link.name}
    </a>
  ))}
</nav>
