// Get icon by name (case-insensitive)
function getIcon(name: string): string {
  const key = name.toLowerCase();
  return icons[key] || icons['website'];
}
---

<div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
  {links.map((link) => (
    <a
      href={link.url}
      target="_blank"
      rel="noopener noreferrer"
      class="glass p-4 flex flex-col items-center gap-3 hover:bg-white/20 transition-all duration-300 hover:scale-105 hover:shadow-lg group"
    >
      <span class="w-8 h-8 text-white group-hover:text-accent transition-colors" set:html={getIcon(link.icon)} />
      <span class="text-sm font-medium text-white/90">{link.name}</span>
    </a>
  ))}
</div>
