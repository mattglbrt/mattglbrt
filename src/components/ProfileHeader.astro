---
interface Props {
  name: string;
  tagline?: string;
  avatarUrl?: string;
}

const { name, tagline, avatarUrl } = Astro.props;
---

<header class="text-center mb-8">
  {avatarUrl ? (
    <div class="w-32 h-32 mx-auto mb-4 rounded-full overflow-hidden ring-4 ring-white/20 shadow-lg">
      <img
        src={avatarUrl}
        alt={name}
        class="w-full h-full object-cover"
      />
    </div>
  ) : (
    <div class="w-32 h-32 mx-auto mb-4 rounded-full bg-gradient-to-br from-accent to-accent-hover flex items-center justify-center ring-4 ring-white/20 shadow-lg">
      <span class="text-4xl font-bold text-white">
        {name.charAt(0).toUpperCase()}
      </span>
    </div>
  )}

  <h1 class="text-3xl sm:text-4xl font-bold text-white mb-2">{name}</h1>

  {tagline && (
    <p class="text-white/70 text-lg max-w-md mx-auto">{tagline}</p>
  )}
</header>
