.72364 -1.70503,30.56413 h -49.17162 c 0.85513,-15.90944 1.70555,-35.7184 1.70555,-51.74693 z"/><path fill="#93c822" d="M 1000,96.45747 845.05541,400.75099 H 788.94926 L 833.49578,316.25589 716.89033,96.45747 h 58.6266 l 85.80469,171.73057 85.56283,-171.73057 z"/></svg>`,
  other: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
};

function getSourceIcon(icon?: string): string {
  if (!icon) return sourceIcons['other'];
  return sourceIcons[icon.toLowerCase()] || sourceIcons['other'];
}
---

<section class="glass-strong p-6 sm:p-8">
  <div class="text-center mb-6">
    <span class="inline-flex items-center gap-2 px-3 py-1 bg-green-500/20 text-green-300 text-sm rounded-full mb-3">
      <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
      Building in Public
    </span>
    <h2 class="text-lg text-white/70 mb-1">{label}</h2>
    <div class="text-5xl sm:text-6xl font-bold text-white tracking-tight">
      <span class="text-green-400">{currency}</span>{formatCurrency(totalRevenue)}
    </div>
  </div>

  {goal && (
    <div class="mb-6">
      <div class="flex justify-between text-sm text-white/60 mb-2">
        <span>Progress to {currency}{formatCurrency(goal)}</span>
        <span>{progressPercentage.toFixed(1)}%</span>
      </div>
      <div class="h-3 bg-white/10 rounded-full overflow-hidden">
        <div
          class="h-full bg-gradient-to-r from-green-400 to-emerald-500 rounded-full transition-all duration-1000 ease-out"
          style={`width: ${progressPercentage}%`}
        ></div>
      </div>
    </div>
  )}

  {sources.length > 0 && (
    <div class="border-t border-white/10 pt-4 mt-4">
      <h3 class="text-sm text-white/50 uppercase tracking-wide mb-3">Revenue Breakdown</h3>
      <div class="grid gap-2">
        {sources.map((source) => (
          <div class="flex items-center justify-between p-3 bg-white/5 rounded-lg hover:bg-white/10 transition-colors">
            <div class="flex items-center gap-3">
              <span class="text-white/70" set:html={getSourceIcon(source.icon)} />
              <span class="text-white/80">{source.name}</span>
            </div>
            <span class="text-white font-medium">
              {currency}{formatCurrency(source.amount)}
            </span>
          </div>
        ))}
      </div>
    </div>
  )}
</section>
