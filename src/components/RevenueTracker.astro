---
interface RevenueSource {
  name: string;
  amount: number;
  icon?: string;
}

interface Props {
  totalRevenue: number;
  goal?: number;
  sources?: RevenueSource[];
  currency?: string;
  label?: string;
}

const {
  totalRevenue,
  goal,
  sources = [],
  currency = "$",
  label = "Revenue Generated",
} = Astro.props;

const progressPercentage = goal ? Math.min((totalRevenue / goal) * 100, 100) : 0;

function formatCurrency(amount: number): string {
  return amount.toLocaleString('en-US', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  });
}

// Source icons
const sourceIcons: Record<string, string> = {
  saas: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>`,
  ads: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/></svg>`,
