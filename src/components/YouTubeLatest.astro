---
interface YouTubeChannel {
  name: string;
  channelId: string;
}

interface Props {
  channels: YouTubeChannel[];
  apiKey?: string;
}

interface VideoData {
  channelName: string;
  videoId: string;
  title: string;
  thumbnail: string;
  publishedAt: string;
}

const { channels, apiKey } = Astro.props;

// Fetch latest video from each channel
async function fetchLatestVideos(): Promise<VideoData[]> {
  if (!apiKey) {
    // Return placeholder data when no API key is provided
    return channels.map((channel) => ({
      channelName: channel.name,
      videoId: 'dQw4w9WgXcQ', // Placeholder
      title: `Latest from ${channel.name}`,
      thumbnail: `https://i.ytimg.com/vi/dQw4w9WgXcQ/mqdefault.jpg`,
      publishedAt: new Date().toISOString(),
    }));
  }

  const videos: VideoData[] = [];

  for (const channel of channels) {
    try {
      // First get the uploads playlist ID
      const channelResponse = await fetch(
        `https://www.googleapis.com/youtube/v3/channels?part=contentDetails&id=${channel.channelId}&key=${apiKey}`
      );
      const channelData = await channelResponse.json();

      if (channelData.items?.[0]) {
        const uploadsPlaylistId = channelData.items[0].contentDetails.relatedPlaylists.uploads;

        // Get latest video from uploads playlist
        const playlistResponse = await fetch(
          `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&maxResults=1&playlistId=${uploadsPlaylistId}&key=${apiKey}`
        );
        const playlistData = await playlistResponse.json();

        if (playlistData.items?.[0]) {
          const video = playlistData.items[0].snippet;
          videos.push({
            channelName: channel.name,
            videoId: video.resourceId.videoId,
            title: video.title,
            thumbnail: video.thumbnails.medium?.url || video.thumbnails.default?.url,
            publishedAt: video.publishedAt,
          });
        }
      }
    } catch (error) {
      console.error(`Error fetching videos for ${channel.name}:`, error);
    }
  }

  return videos;
}

const videos = await fetchLatestVideos();

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}
---

<section class="space-y-4">
  <h2 class="text-xl font-bold text-white flex items-center gap-2">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="text-red-500">
      <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
      <path d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="white"/>
    </svg>
    Latest Videos
  </h2>

  <div class="grid gap-4 md:grid-cols-2">
    {videos.map((video) => (
      <a
        href={`https://www.youtube.com/watch?v=${video.videoId}`}
        target="_blank"
        rel="noopener noreferrer"
        class="glass overflow-hidden hover:bg-white/20 transition-all duration-300 hover:scale-[1.02] group block"
      >
        <div class="aspect-video relative overflow-hidden">
          <img
            src={video.thumbnail}
            alt={video.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors flex items-center justify-center">
            <div class="w-16 h-16 bg-red-600 rounded-full flex items-center justify-center opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="white">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
        </div>
        <div class="p-4">
          <span class="text-xs text-white/60 uppercase tracking-wide">{video.channelName}</span>
          <h3 class="text-white font-medium mt-1 line-clamp-2">{video.title}</h3>
          <p class="text-white/50 text-sm mt-2">{formatDate(video.publishedAt)}</p>
        </div>
      </a>
    ))}
  </div>

  {!apiKey && (
    <p class="text-white/50 text-sm text-center mt-2">
      Add your YouTube API key to fetch real videos
    </p>
  )}
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
