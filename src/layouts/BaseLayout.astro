---
import { ClientRouter } from "astro:transitions";
import type { ImageMetadata } from 'astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import { settings } from '../data/settings';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/900.css';
import '../styles/main.scss';

export interface Props {
  title?: string;
  description?: string;
  image?: ImageMetadata | string;
  hideFooterWidgets?: boolean;
}

const {
  description = settings.site.description,
  image = settings.site.image,
  hideFooterWidgets = false,
} = Astro.props;

const title = [...new Set([Astro.props.title, settings.site.title])].filter(Boolean).join(' | ');
const canonicalURL = new URL(Astro.url.pathname, Astro.site || settings.site.url);
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const imageUrl = typeof image === 'string'
  ? image
  : image?.src
    ? new URL(image.src, Astro.site || settings.site.url).toString()
    : settings.site.image;
---

<!doctype html>
<html lang={settings.site.language || 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}

    <link rel="sitemap" href={`${base}sitemap-index.xml`} />
    <link rel="alternate" type="application/rss+xml" title="RSS" href={`${base}rss.xml`} />

    {settings.analytics.google && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${settings.analytics.google}`}></script>
      <script is:inline define:vars={{ gaId: settings.analytics.google }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        const sendConfig = () => {
          gtag('config', gaId, {
            page_path: window.location.pathname,
          });
        };

        sendConfig();

        document.addEventListener('astro:page-load', sendConfig);
      </script>
    )}
  </head>
  <body>
    <Header />
    <main class="content">
      <slot />
    </main>
    <ScrollToTop />
    <Footer hideWidgets={hideFooterWidgets} />

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox">
      <button class="lightbox__close" aria-label="Close">&times;</button>
      <button class="lightbox__nav lightbox__nav--prev" aria-label="Previous">&lsaquo;</button>
      <button class="lightbox__nav lightbox__nav--next" aria-label="Next">&rsaquo;</button>
      <img class="lightbox__img" src="" alt="" />
      <div class="lightbox__counter"></div>
    </div>

    <script>
      import '../scripts/common.ts';
    </script>

    <script>
      function initLightbox() {
        const lightbox = document.getElementById('lightbox') as HTMLElement;
        const lightboxImg = lightbox.querySelector('.lightbox__img') as HTMLImageElement;
        const lightboxClose = lightbox.querySelector('.lightbox__close') as HTMLElement;
        const lightboxPrev = lightbox.querySelector('.lightbox__nav--prev') as HTMLElement;
        const lightboxNext = lightbox.querySelector('.lightbox__nav--next') as HTMLElement;
        const lightboxCounter = lightbox.querySelector('.lightbox__counter') as HTMLElement;

        let images: string[] = [];
        let currentIndex = 0;
        let touchStartX = 0;
        let touchEndX = 0;

        function show(index: number) {
          currentIndex = ((index % images.length) + images.length) % images.length;
          lightboxImg.src = images[currentIndex];
          lightboxCounter.textContent = `${currentIndex + 1} / ${images.length}`;
        }

        function open(galleryImages: string[], startIndex: number) {
          images = galleryImages;
          show(startIndex);
          lightbox.classList.add('is-active');
          document.body.style.overflow = 'hidden';
        }

        function close() {
          lightbox.classList.remove('is-active');
          document.body.style.overflow = '';
        }

        // Click gallery images to open
        document.querySelectorAll('.gallery img').forEach((img) => {
          img.addEventListener('click', () => {
            const gallery = (img as HTMLElement).closest('.gallery');
            if (!gallery) return;
            const galleryImgs = Array.from(gallery.querySelectorAll('img'));
            const srcs = galleryImgs.map((i) => (i as HTMLImageElement).src);
            const idx = galleryImgs.indexOf(img as HTMLImageElement);
            open(srcs, idx);
          });
        });

        lightboxClose.addEventListener('click', close);
        lightboxPrev.addEventListener('click', () => show(currentIndex - 1));
        lightboxNext.addEventListener('click', () => show(currentIndex + 1));

        // Click backdrop to close
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) close();
        });

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
          if (!lightbox.classList.contains('is-active')) return;
          if (e.key === 'Escape') close();
          if (e.key === 'ArrowLeft') show(currentIndex - 1);
          if (e.key === 'ArrowRight') show(currentIndex + 1);
        });

        // Touch swipe
        lightbox.addEventListener('touchstart', (e) => {
          touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        lightbox.addEventListener('touchend', (e) => {
          touchEndX = e.changedTouches[0].screenX;
          const diff = touchStartX - touchEndX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) show(currentIndex + 1);
            else show(currentIndex - 1);
          }
        }, { passive: true });
      }

      // Init on page load and Astro transitions
      initLightbox();
      document.addEventListener('astro:page-load', initLightbox);
    </script>
  </body>
</html>