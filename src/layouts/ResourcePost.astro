---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

type Props = CollectionEntry<'resources'>['data'] & { id: string };

const { title, description, pubDate, updatedDate, heroImage, tags, id } = Astro.props;

// Generate dynamic OG image URL based on post slug
const slug = id.replace(/\.md$/, '');
const ogImage = `/og/resources/${slug}.png`;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description} image={ogImage}>
  <article>
    <!-- Header -->
    <header class="glass-strong p-6 sm:p-8 mb-6">
        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{title}</h1>

        <div class="flex flex-wrap items-center gap-4 text-white/60 text-sm">
          <time datetime={pubDate.toISOString()}>
            {formattedPubDate}
          </time>
          {updatedDate && (
            <span>
              (Updated: {formattedUpdatedDate})
            </span>
          )}
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <span class="px-2 py-1 bg-white/10 text-white/70 text-xs rounded">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Hero image -->
      {heroImage && (
        <div class="glass overflow-hidden mb-6">
          <img
            src={heroImage}
            alt={title}
            class="w-full h-auto"
          />
        </div>
      )}

    <!-- Content -->
    <div class="glass p-6 sm:p-8 prose prose-invert prose-lg max-w-none">
      <slot />
    </div>
  </article>
</Layout>

<style is:global>
  .prose {
    color: rgba(255, 255, 255, 0.9);
  }

  .prose h1, .prose h2, .prose h3, .prose h4 {
    color: white;
    font-weight: 700;
  }

  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .prose a {
    color: #3b82f6;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #2563eb;
  }

  .prose strong {
    color: white;
  }

  .prose code {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .prose pre {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
  }

  .prose pre code {
    background: transparent;
    padding: 0;
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
  }

  .prose li {
    margin: 0.5rem 0;
  }

  .prose blockquote {
    border-left: 4px solid #3b82f6;
    padding-left: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
  }

  .prose hr {
    border-color: rgba(255, 255, 255, 0.2);
    margin: 2rem 0;
  }

  .prose img {
    border-radius: 0.5rem;
  }
</style>
