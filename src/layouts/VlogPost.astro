---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';

type Props = CollectionEntry<'vlog'>['data'] & { id: string };

const { title, description, pubDate, updatedDate, videoId, videoUrl, channelName, duration, tags, id } = Astro.props;

// Generate dynamic OG image URL based on post slug
const slug = id.replace(/\.md$/, '');
const ogImage = `/og/vlog/${slug}.png`;

const formattedPubDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={title} description={description} image={ogImage}>
  <article>
    <!-- Header -->
    <header class="glass-strong p-6 sm:p-8 mb-6">
        {channelName && (
          <span class="inline-block px-3 py-1 bg-red-500/20 text-red-300 text-sm rounded-full mb-4">
            {channelName}
          </span>
        )}

        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">{title}</h1>

        <div class="flex flex-wrap items-center gap-4 text-white/60 text-sm">
          <time datetime={pubDate.toISOString()}>
            {formattedPubDate}
          </time>
          {updatedDate && (
            <span>
              (Updated: {formattedUpdatedDate})
            </span>
          )}
          {duration && (
            <span class="flex items-center gap-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              {duration}
            </span>
          )}
        </div>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map((tag) => (
              <span class="px-2 py-1 bg-white/10 text-white/70 text-xs rounded">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Video embed -->
      <div class="glass overflow-hidden mb-6">
        <div class="aspect-video">
          <iframe
            src={`https://www.youtube.com/embed/${videoId}`}
            title={title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
          ></iframe>
        </div>
      </div>

      <!-- Transcript Content -->
      <div class="glass p-6 sm:p-8 prose prose-invert prose-lg max-w-none">
        <h2 class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" x2="8" y1="13" y2="13"/>
            <line x1="16" x2="8" y1="17" y2="17"/>
            <line x1="10" x2="8" y1="9" y2="9"/>
          </svg>
          Transcript
        </h2>
        <slot />
      </div>

      <!-- Watch on YouTube CTA -->
      {videoUrl && (
        <div class="mt-6 text-center">
          <a
            href={videoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-lg transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
              <path d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z" fill="white"/>
            </svg>
            Watch on YouTube
          </a>
        </div>
      )}
  </article>
</Layout>

<style is:global>
  .prose {
    color: rgba(255, 255, 255, 0.9);
  }

  .prose h1, .prose h2, .prose h3, .prose h4 {
    color: white;
    font-weight: 700;
  }

  .prose h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .prose a {
    color: #3b82f6;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #2563eb;
  }

  .prose strong {
    color: white;
  }

  .prose code {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .prose pre {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
  }

  .prose pre code {
    background: transparent;
    padding: 0;
  }

  .prose ul, .prose ol {
    padding-left: 1.5rem;
  }

  .prose li {
    margin: 0.5rem 0;
  }

  .prose blockquote {
    border-left: 4px solid #3b82f6;
    padding-left: 1rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
  }

  .prose hr {
    border-color: rgba(255, 255, 255, 0.2);
    margin: 2rem 0;
  }

  .prose img {
    border-radius: 0.5rem;
  }
</style>
