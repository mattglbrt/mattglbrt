ldren":["$","$Ld",null,{"id":"about-matt-gilbert","title":"About Matt Gilbert","children":["\n",["$","$Le",null,{"src":{"src":"/_next/static/media/wecancreate.b2aa83a1.png","height":666,"width":1728,"blurDataURL":"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAgAAAADCAMAAACZFr56AAAALVBMVEXy3rbcycN7jafbxLPTuq3Bl4v14az5ypTOrZ3OvbOcjpL25MW1padhbHjiz8AYeKI0AAAACXBIWXMAAAsTAAALEwEAmpwYAAAAI0lEQVR4nGPgZWJhZGZmZGdg4mFlZGFh5mZg4uLgY2BgYAMABjAAdYWclnwAAAAASUVORK5CYII=","blurWidth":8,"blurHeight":3},"alt":""}],"\n",["$","h2",null,{"children":["$","$Lf",null,{"href":"#about-matt-gilbert","children":"About Matt Gilbert"}]}],"\n",["$","p",null,{"children":"I am dedicated to the overall success of my clients. Thats why I take a holistic approach to marketing and sales."}],"\n",["$","p",null,{"children":"4 Years as a solo consultant, 28 Businesses Helped, 39 Websites Built"}],"\n",["$","h2",null,{"id":"32m-in-client-revenue-generated","children":["$","$Lf",null,{"href":"#32m-in-client-revenue-generated","children":"3.2m in client revenue generated"}]}],"\n",["$","h2",null,{"id":"my-mission","children":["$","$Lf",null,{"href":"#my-mission","children":"My Mission"}]}],"\n",["$","p",null,{"children":"To help create as many successful entreprenuers as possible."}],"\n",["$","p",null,{"children":"I believe that the human imperative is to create, and entrepreneurship is the best avenue for creation."}],"\n",["$","p",null,{"children":"My goal is to bring the strategies and technology utilized by multimillion dollar companies to small business owners, soloprenuers, and bootstrapped start ups. If you are a mulimillion dollar company, do not worry, I still want to work with you too."}],"\n",["$","h2",null,{"id":"my-values","children":["$","$Lf",null,{"href":"#my-values","children":"My Values"}]}],"\n",["$","h3",null,{"id":"honesty","children":"Honesty"}],"\n",["$","p",null,{"children":"Stats and KPIs should be an accurate measurement of progression. I never hide behind stats or morph them to make our performance look better than it is."}],"\n",["$","h3",null,{"id":"transparency","children":"Transparency"}],"\n",["$","p",null,{"children":"I will tell you exactly what I am doing, why I am doing it, and most importantly, how I am doing it. I build systems and standard operating procedures that work without me and I am adamently opposed to vendor lock in."}],"\n",["$","h3",null,{"id":"accountability","children":"Accountability"}],"\n",["$","p",null,{"children":"Most business initiaves fail due to lack of accountability. I bear the full weight of our actions and own the work I do for you. Period."}],"\n",["$","p",null,{"children":"I have nearly two decades of experience in the IT, Marketing, SaaS, and Sales industries. I am changing the way things are done surrounding website development. My focus is on overall organization success. A website by itself accomplishes nothing."}],"\n",["$","h2",null,{"id":"view-my-cv","children":["$","$Lf",null,{"href":"#view-my-cv","children":["$","$Lf",null,{"href":"https://themattgilbert.com","children":"View my CV."}]}]}],"\n",["$","$Le",null,{"src":{"src":"/_next/static/media/wecancreate.b2aa83a1.png","height":666,"width":1728,"blurDataURL":"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAgAAAADCAMAAACZFr56AAAALVBMVEXy3rbcycN7jafbxLPTuq3Bl4v14az5ypTOrZ3OvbOcjpL25MW1padhbHjiz8AYeKI0AAAACXBIWXMAAAsTAAALEwEAmpwYAAAAI0lEQVR4nGPgZWJhZGZmZGdg4mFlZGFh5mZg4uLgY2BgYAMABjAAdYWclnwAAAAASUVORK5CYII=","blurWidth":8,"blurHeight":3},"alt":""}],"\n",["$","h2",null,{"id":"revops-for-small-business--startups","children":["$","$Lf",null,{"href":"#revops-for-small-business--startups","children":"RevOps for Small Business & Startups"}],"date":"2024-01-01T00:00Z"}],"\n",["$","p",null,{"children":"I optimize your sales and marketing operations to boost profits, streamline sales, and elevate your brand."}],"\n",["$","h3",null,{"id":"how-revops-and-everyway-can-help-transform-your-organization","children":"How RevOps and Everyway can help transform your organization."}],"\n",["$","h4",null,{"id":"increase-your-leads","children":"Increase Your Leads"}],"\n",["$","p",null,{"children":"Unite sales, marketing, and development to build successful sales pipelines that drive net new leads as well as retain current customers."}],"\n",["$","h4",null,{"id":"increase-your-profit","children":"Increase Your Profit"}],"\n",["$","p",null,{"children":"Streamline business processes, systematize procedures, and identify bottlenecks, resulting in improved operational efficiency and reduced costs."}],"\n",["$","h4",null,{"id":"develop-consistency","children":"Develop Consistency"}],"\n",["$","p",null,{"children":"Establish standard operatiing procedures, key metrics, and reporting methods tailored to your organization to build efficient, scalable, and successful teams."}],"\n",["$","h4",null,{"id":"go-to-market","children":"Go to Market"}],"\n",["$","p",null,{"children":"I provide a strategic roadmap and expert guidance to create a successful market entry, helping you reach your target audience, outperform competitors, and achieve rapid growth."}],"\n",["$","h3",null,{"id":"no-really-what-do-you-do","children":"No Really What Do You Do?"}],"\n",["$","p",null,{"children":"Although I custom tailor my service offerings to each client based on their goals, my services typically fall into these categories."}],"\n",["$","h4",null,{"id":"positioning","children":"Positioning"}],"\n",["$","p",null,{"children":"Establish product market fit and your ideal customer profile."}],"\n",["$","p",null,{"children":"I research and find your ideal customers, determine the best ways to get infront of them, and then craft your messaging, core story, and branding to appeal to them."}],"\n",["$","h4",null,{"id":"go-to-market-1","children":"Go to Market"}],"\n",["$","p",null,{"children":"Websites, email marketing, content marketing, paid advertising, & SEO."}],"\n",["$","p",null,{"children":"Instead of offering piecemeal marketing services, we utilize every channel available to build cohesive marketing campaigns, resulting in higher ROI on your marketing budget."}],"\n",["$","h4",null,{"id":"sales--marketing-technology","children":"Sales & Marketing technology"}],"\n",["$","p",null,{"children":"I handle the technology that brings it all together."}],"\n",["$","p",null,{"children":"I have the expertise to build your MarTech stack from the ground up, or integrate with your current CRM. If you have no clue about what any of that means, I have your covered too."}]],"date":"2024-01-14T00:00Z"}]}]]}]],null],"segment":"__PAGE__"},"styles":[]}]}]}]}],null]
5:[["$","meta","0",{"charSet":"utf-8"}],["$","title","1",{"children":"Matt Gilbert | Thoughts on entrepreneurship, marketing, sales, and fatherhood."}],["$","meta","2",{"name":"description","content":"I help people become business owners, and enable business owners to become successful entreprenuers."}],["$","meta","3",{"name":"viewport","content":"width=device-width, initial-scale=1"}],["$","link","4",{"rel":"alternate","type":"application/rss+xml","href":"https://mattglbrt.com/feed.xml"}],["$","link","5",{"rel":"icon","href":"/favicon.ico","type":"image/x-icon","sizes":"16x16"}],["$","meta","6",{"name":"next-size-adjust"}]]
